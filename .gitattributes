# Normalize line endings: text files use LF in the repo.
* text=auto eol=lf

# Windows batch/powershell scripts must stay CRLF to run correctly.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
*.mp3 binary
*.exe binary
